function renderAA(){
  if(!D.aaPeople.length)return`<div class="empty" style="margin-top:40px"><div class="empty-ic"><i class="ti ti-users"></i></div><div class="et">还没有分账记录</div><div class="es">添加朋友或女朋友<br>开始记录 AA 消费</div></div><button class="add-btn" onclick="openModal('addAAPerson')"><i class="ti ti-user-plus"></i>添加分账对象</button>`;
  let tThey=0,tMe=0;D.aaPeople.forEach(p=>{const b=aaBal(p);tThey+=b.they;tMe+=b.me;});
  let h=`<div class="sg"><div class="sc"><div class="sl">别人欠我</div><div class="sv g">${fmt(tThey)}</div></div><div class="sc"><div class="sl">我欠别人</div><div class="sv r">${fmt(tMe)}</div></div></div>`;
  D.aaPeople.forEach(p=>{const{net}=aaBal(p),unsettled=p.txns.filter(t=>!t.settled),settled=p.txns.filter(t=>t.settled),isOpen=U.expandedId===p.id;
    h+=`<div class="aa-p"><div class="aa-h" onclick="toggle(${p.id})"><div class="aa-av" style="background:${p.color}22;color:${p.color}">${p.name.slice(0,2).toUpperCase()}</div><div class="aa-info"><div class="aa-name">${p.name}</div><div class="aa-sub">${unsettled.length} 笔未结算</div></div><div class="aa-bal"><div class="aa-num" style="color:${net>0?'var(--green)':net<0?'var(--red)':'var(--text3)'}">${net===0?'—':(net>0?'+':'−')+fmtR(net)}</div><div class="aa-lbl">${net>0?'they owe':net<0?'you owe':'all clear'}</div></div><i class="ti ti-chevron-down chevron ${isOpen?'rot':''}"></i></div>`;
    if(isOpen){h+=`<div class="aa-body">`;if(!unsettled.length&&!settled.length)h+=`<div style="padding:18px 0;text-align:center;font-size:13px;color:var(--text3)">还没有记录，加一笔！</div>`;
      if(unsettled.length){h+=`<div class="po-lbl" style="margin:13px 0 6px">未结算</div>`;unsettled.forEach(t=>{const myShare=t.total/t.split,owedAmt=myShare*(t.split-1),iAmOwed=t.paidBy==='me';h+=`<div class="aa-txn"><div class="aa-txn-ic"><i class="ti ${t.catIcon||'ti-receipt'}"></i></div><div class="aa-txn-m"><div class="aa-txn-n">${t.desc}</div><div class="aa-txn-s">${t.catLabel||''} · ${t.date}${t.payName?' · '+t.payName:''} · 共${fmtR(t.total)} ÷${t.split}</div></div><div class="aa-txn-r"><div class="aa-txn-a" style="color:${iAmOwed?'var(--green)':'var(--red)'}">${iAmOwed?'+':'−'}${fmtR(owedAmt)}</div><div class="aa-txn-w">${iAmOwed?p.name.split(' ')[0]+' owes':'you owe'}</div></div><i class="ti ti-edit" onclick="openModal('addAATxn',{activePersonId:${p.id},activeEditTxnId:${t.id}})" style="color:var(--accent);font-size:19px;padding:4px"></i><i class="ti ti-x" onclick="delAATxn(${p.id},${t.id})" style="color:var(--text3);font-size:19px;padding:4px"></i></div>`;});}
      if(settled.length){h+=`<div class="po-lbl" style="margin:13px 0 6px">已结算 (${settled.length})</div>`;settled.slice(-2).forEach(t=>{h+=`<div class="aa-txn" style="opacity:.4"><div class="aa-txn-ic"><i class="ti ti-check"></i></div><div class="aa-txn-m"><div class="aa-txn-n" style="text-decoration:line-through">${t.desc}</div><div class="aa-txn-s">${t.date}</div></div><div class="aa-txn-r"><div class="aa-txn-a" style="color:var(--text3)">${fmtR(t.total/t.split)}</div></div></div>`;});}
      h+=`<div class="aa-acts"><button class="btn pay" onclick="openModal('addAATxn',{activePersonId:${p.id},selPaidBy:'me',selSplit:2})"><i class="ti ti-plus"></i>加记录</button>${net!==0?`<button class="btn topup" onclick="settleAA(${p.id})"><i class="ti ti-check"></i>结算</button>`:''}<button class="btn del" onclick="delAAPerson(${p.id})"><i class="ti ti-trash"></i></button></div></div>`;}
    h+=`</div>`;});
  h+=`<button class="add-btn" onclick="openModal('addAAPerson')"><i class="ti ti-user-plus"></i>添加分账对象</button>`;
  return h;
}

function render(){
  if(LOCK.state!=='unlocked'){renderLock();return;}
  const TABS=[{id:'home',i:'ti-home',l:'首页'},{id:'cards',i:'ti-credit-card',l:'卡片'},{id:'record',i:'ti-circle-plus',l:'记账'},{id:'history',i:'ti-calendar',l:'记录'},{id:'fixed',i:'ti-repeat',l:'固定'},{id:'aa',i:'ti-users',l:'AA'}];
  const TITLES={home:'RinggitMe',cards:'卡片管理',record:'收入 & 记账',history:'消费记录',fixed:'固定支出',aa:'AA 分账'};
  const SUBS={home:'马来西亚理财 · 数据存本机',cards:'信用卡 · 储蓄 · eWallet',record:'收入追踪 · 快速记账',history:'按日期查看消费',fixed:'订阅 · 贷款 · 租金',aa:'分账追踪 · 随时结算'};
  let content=U.tab==='home'?renderHome():U.tab==='cards'?renderCards():U.tab==='record'?renderRecord():U.tab==='history'?renderHistory():U.tab==='fixed'?renderFixed():renderAA();
  document.getElementById('app').innerHTML=`
    <div class="topbar">
      <div><div class="t-title">${TITLES[U.tab]}</div><div class="t-sub">${SUBS[U.tab]}</div></div>
      <div class="t-r">
        <div class="t-ic" onclick="togglePrivacy()" title="隐私模式"><i class="ti ${D.privacyMode?'ti-eye-off':'ti-eye'}" style="color:${D.privacyMode?'var(--orange)':'var(--text2)'}"></i></div>
        <div class="t-ic" onclick="lockApp()" title="锁定"><i class="ti ti-lock"></i></div>
      </div>
    </div>
    <div class="content">${content}</div>
    <div class="nav">${TABS.map(t=>`<button class="ni ${U.tab===t.id?'on':''}" onclick="setTab('${t.id}')"><i class="ti ${t.i}"></i>${t.l}</button>`).join('')}</div>
    ${buildModal()}`;
}

// ── START ──
initSecurity();
</script>
</body>
