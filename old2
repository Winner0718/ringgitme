  if(D.incomeMode==='fullcomm'&&(totalSub+totalLoan)>0)h+=`<div class="ib w"><i class="ti ti-target-arrow"></i>本月固定开销 ${fmtR(totalSub+totalLoan)}，至少要赚这么多才 cover。</div>`;
