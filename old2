// ══════════════════════════════════════════════════════
// LOCK SCREEN LOGIC  (auto-prompts Face ID ONCE — no loop)
// ══════════════════════════════════════════════════════
async function initSecurity(){
  const hasCred=SEC.hasSavedCred(),hasPIN=SEC.hasPIN();
  if(!hasCred&&!hasPIN)LOCK.state='setup_choice';
  else if(hasCred)LOCK.state='locked_face';
  else LOCK.state='locked_pin';
  renderLock();
}
async function tryFaceUnlock(){
  LOCK.pinError='';renderLock();
  const ok=await SEC.verifyWebAuthn();
  if(ok){unlock();return;}
  // Failure: fall back, do NOT re-trigger automatically
  if(SEC.hasPIN()){LOCK.state='locked_pin';LOCK.pinError='Face ID 失败，请输入 PIN';}
  else{LOCK.pinError='Face ID 验证未通过，点按钮重试';}
  renderLock();
}
async function setupFaceId(){
  LOCK.state='setup_webauthn';renderLock();
  const ok=await SEC.setupWebAuthn();
  if(ok){toast('✓ Face ID 设置成功');unlock();}
  else{LOCK.state='setup_pin';LOCK.setupPinStep=1;LOCK.setupPin='';LOCK.setupPinFirst='';LOCK.pinError='Face ID 不可用，请设置 PIN';renderLock();}
}
function startPinSetup(){LOCK.state='setup_pin';LOCK.setupPinStep=1;LOCK.setupPin='';LOCK.setupPinFirst='';LOCK.pinError='';renderLock();}
async function pinKeyPress(key){
  if(LOCK.state==='setup_pin'){
    if(LOCK.setupPin.length>=4)return;
    LOCK.setupPin+=key;LOCK.pinError='';renderLock();
    if(LOCK.setupPin.length===4){await new Promise(r=>setTimeout(r,250));
      if(LOCK.setupPinStep===1){LOCK.setupPinFirst=LOCK.setupPin;LOCK.setupPin='';LOCK.setupPinStep=2;renderLock();}
      else{if(LOCK.setupPin===LOCK.setupPinFirst){await SEC.savePin(LOCK.setupPin);toast('✓ PIN 设置成功');unlock();}
        else{LOCK.pinError='两次不一致，重新设置';LOCK.setupPin='';LOCK.setupPinStep=1;LOCK.setupPinFirst='';renderLock();}}}
  }else if(LOCK.state==='locked_pin'){
    if(LOCK.pinInput.length>=4)return;
    LOCK.pinInput+=key;LOCK.pinError='';renderLock();
    if(LOCK.pinInput.length===4){await new Promise(r=>setTimeout(r,250));
      if(await SEC.verifyPin(LOCK.pinInput))unlock();
      else{LOCK.pinAttempts++;LOCK.pinError=LOCK.pinAttempts>=5?'尝试次数过多':'PIN 错误，请重试';LOCK.pinInput='';renderLock();}}}
}
function pinDel(){if(LOCK.state==='setup_pin'){LOCK.setupPin=LOCK.setupPin.slice(0,-1);renderLock();}else if(LOCK.state==='locked_pin'){LOCK.pinInput=LOCK.pinInput.slice(0,-1);renderLock();}}
function unlock(){LOCK.state='unlocked';LOCK.pinInput='';LOCK.pinError='';LOCK.pinAttempts=0;LOCK.faceAutoTried=false;render();}
function lockApp(){const hasCred=SEC.hasSavedCred();LOCK.state=hasCred?'locked_face':(SEC.hasPIN()?'locked_pin':'setup_choice');LOCK.pinInput='';LOCK.pinError='';LOCK.faceAutoTried=true;/*manual lock → no auto face*/renderLock();}

// Re-lock when app returns from background — but DON'T auto-trigger face
document.addEventListener('visibilitychange',()=>{
  if(!document.hidden&&LOCK.state==='unlocked'){
    const hasCred=SEC.hasSavedCred(),hasPIN=SEC.hasPIN();
    if(hasCred||hasPIN){LOCK.state=hasCred?'locked_face':'locked_pin';LOCK.pinInput='';LOCK.faceAutoTried=true;renderLock();}
  }
});

function renderLock(){
  const app=document.getElementById('app');
  const pin=LOCK.state==='setup_pin'?LOCK.setupPin:LOCK.pinInput;
  const pinLen=pin.length;
  if(LOCK.state==='unlocked'){render();return;}
  let html='<div class="lock-screen">';
  html+=`<div class="lock-logo"><i class="ti ti-shield-lock"></i></div>`;
  if(LOCK.state==='checking'){html+=`<div class="lock-title">RinggitMe</div><div class="lock-sub">正在验证…</div>`;}
  else if(LOCK.state==='setup_choice'){
    html+=`<div class="lock-title">保护你的数据</div><div class="lock-sub">第一次使用，选择解锁方式。数据只存在这台设备上。</div>`;
    if(SEC.isWebAuthnAvailable()){html+=`<button class="face-btn" onclick="setupFaceId()"><i class="ti ti-face-id" style="font-size:20px"></i>用 Face ID 解锁</button>
      <button class="face-btn ghost" onclick="startPinSetup()"><i class="ti ti-lock" style="font-size:18px"></i>用 PIN 码解锁</button>`;}
    else{html+=`<div class="setup-box"><p>当前环境不支持 Face ID（需在 HTTPS 或加到主屏幕后才可用），先用 4 位 PIN 码保护。</p></div>
      <button class="face-btn" onclick="startPinSetup()"><i class="ti ti-lock" style="font-size:18px"></i>设置 PIN 码</button>`;}
  }
  else if(LOCK.state==='setup_webauthn'){html+=`<div class="lock-title">设置 Face ID</div><div class="lock-sub">请按设备提示完成验证…</div><div style="font-size:46px;margin-top:18px">🔐</div>`;}
  else if(LOCK.state==='setup_pin'){
    html+=`<div class="lock-title">${LOCK.setupPinStep===1?'设置 PIN 码':'确认 PIN 码'}</div>
    <div class="lock-sub">${LOCK.setupPinStep===1?'输入 4 位数字':'再输入一次'}</div>
    <div class="pin-display">${[0,1,2,3].map(i=>`<div class="pin-dot ${i<pinLen?'filled':''}"></div>`).join('')}</div>
    <div class="pin-error">${LOCK.pinError}</div>${buildPinPad()}`;
  }
  else if(LOCK.state==='locked_face'){
    html+=`<div class="lock-title">RinggitMe</div><div class="lock-sub">用 Face ID 解锁你的财务数据</div>
    <button class="face-btn" onclick="tryFaceUnlock()"><i class="ti ti-face-id" style="font-size:20px"></i>Face ID 解锁</button>
    <div class="pin-error">${LOCK.pinError}</div>`;
    if(SEC.hasPIN())html+=`<div class="pin-btn-link" onclick="LOCK.state='locked_pin';LOCK.pinInput='';LOCK.pinError='';renderLock()">改用 PIN 码</div>`;
  }
  else if(LOCK.state==='locked_pin'){
    html+=`<div class="lock-title">RinggitMe</div><div class="lock-sub">输入 PIN 码解锁</div>
    <div class="pin-display">${[0,1,2,3].map(i=>`<div class="pin-dot ${i<pinLen?(LOCK.pinError?'error':'filled'):''}"></div>`).join('')}</div>
    <div class="pin-error">${LOCK.pinError}</div>
    ${LOCK.pinAttempts>0&&LOCK.pinAttempts<5?`<div class="pin-attempts">剩余尝试：${5-LOCK.pinAttempts} 次</div>`:''}
    ${buildPinPad()}`;
    if(SEC.hasSavedCred())html+=`<div class="pin-btn-link" onclick="LOCK.state='locked_face';LOCK.pinInput='';LOCK.pinError='';renderLock()"><i class="ti ti-face-id" style="font-size:14px;vertical-align:-2px"></i> 改用 Face ID</div>`;
  }
