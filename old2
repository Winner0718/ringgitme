function renderHome(){
  const ccs=D.cards.filter(c=>c.type==='cc'),savs=D.cards.filter(c=>c.type==='saving'),ews=D.cards.filter(c=>c.type==='ew');
  const totalOwed=ccs.reduce((a,c)=>a+c.owed,0),totalSav=savs.reduce((a,c)=>a+c.balance,0),totalEw=ews.reduce((a,c)=>a+c.balance,0);
  const totalSub=D.subs.reduce((a,s)=>a+s.amt,0),totalLoan=D.loans.reduce((a,l)=>a+l.monthly,0);
  const net=totalSav+totalEw-totalOwed;
  const now=new Date(),thisMonth=D.txns.filter(t=>{const d=new Date(t.isoDate||Date.now());return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();}).reduce((a,t)=>a+t.amt,0);
