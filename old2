<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,user-scalable=no"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="RinggitMe"/>
<meta name="theme-color" content="#0e1116" media="(prefers-color-scheme:dark)"/>
<meta name="theme-color" content="#f4f5f7" media="(prefers-color-scheme:light)"/>
<title>RinggitMe</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#f4f5f7;--bg2:#ffffff;--bg3:#eef0f3;--bg4:#e4e7ec;
  --text:#0d121c;--text2:#475067;--text3:#98a1b3;
  --border:#e7e9ee;--border2:#d7dbe3;
  --green:#0e9f6e;--green-bg:#e6f6ef;--red:#e0322a;--red-bg:#fdecec;
  --blue:#2563eb;--blue-bg:#e8f0fe;--orange:#e07b00;--orange-bg:#fef3e2;--purple:#7c3aed;--purple-bg:#f1ebfe;
  --accent:#2563eb;--accent2:#7c3aed;
  --shadow:0 1px 2px rgba(16,24,40,.04),0 4px 16px rgba(16,24,40,.06);
  --shadow-lg:0 8px 30px rgba(16,24,40,.12);
  --r:16px;--rl:20px;--rx:26px;
  --safe-top:env(safe-area-inset-top,0px);--safe-bot:env(safe-area-inset-bottom,0px);
}
@media(prefers-color-scheme:dark){:root{
  --bg:#0e1116;--bg2:#171b22;--bg3:#1e232c;--bg4:#283039;
  --text:#f2f4f8;--text2:#aab2c2;--text3:#697185;
  --border:#262c36;--border2:#333b48;
  --green:#2dd48f;--green-bg:#0d2a1e;--red:#ff5b52;--red-bg:#2c100e;
  --blue:#5b8def;--blue-bg:#10203d;--orange:#f5a623;--orange-bg:#2a1b04;--purple:#a77ef0;--purple-bg:#1c1331;
  --accent:#5b8def;--accent2:#a77ef0;
  --shadow:0 1px 2px rgba(0,0,0,.3),0 4px 16px rgba(0,0,0,.35);
  --shadow-lg:0 10px 34px rgba(0,0,0,.5);
}}
html,body{height:100%}
body{font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Inter',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;-webkit-font-smoothing:antialiased;position:fixed;inset:0}
.app{position:fixed;top:0;bottom:0;left:0;right:0;margin:0 auto;max-width:440px;display:flex;flex-direction:column;overflow:hidden;background:var(--bg)}

/* ── LOCK SCREEN ── */
.lock-screen{position:absolute;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 30px calc(var(--safe-bot) + 30px);z-index:200;text-align:center}
.lock-logo{width:76px;height:76px;border-radius:22px;background:linear-gradient(140deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;margin:0 auto 22px;box-shadow:0 10px 30px rgba(37,99,235,.35)}
.lock-logo i{font-size:34px;color:#fff}
.lock-title{font-size:25px;font-weight:800;letter-spacing:-.5px;margin-bottom:7px}
.lock-sub{font-size:14px;color:var(--text3);line-height:1.55;margin-bottom:34px;max-width:280px}
.face-btn{width:100%;max-width:320px;padding:15px;border-radius:15px;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#fff;font-size:16px;font-weight:650;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:12px;box-shadow:0 6px 20px rgba(37,99,235,.32)}
.face-btn:active{transform:scale(.98);opacity:.92}
.face-btn.ghost{background:var(--bg2);color:var(--text);border:1px solid var(--border2);box-shadow:none}
.pin-btn-link{font-size:14px;color:var(--accent);cursor:pointer;padding:10px;margin-top:2px;font-weight:600}
.setup-box{width:100%;max-width:320px;background:var(--bg2);border-radius:16px;padding:18px;margin-bottom:20px;border:1px solid var(--border);box-shadow:var(--shadow);text-align:left}
.setup-box p{font-size:13px;color:var(--text2);line-height:1.6}
.pin-display{display:flex;gap:16px;justify-content:center;margin:22px 0}
.pin-dot{width:13px;height:13px;border-radius:50%;border:2px solid var(--border2);background:transparent;transition:all .15s}
.pin-dot.filled{background:var(--accent);border-color:var(--accent);transform:scale(1.05)}
.pin-dot.error{background:var(--red);border-color:var(--red)}
.pin-pad{display:grid;grid-template-columns:repeat(3,76px);gap:14px;margin:14px auto 0}
.pin-key{height:72px;border-radius:50%;border:none;background:var(--bg2);font-size:26px;font-weight:500;cursor:pointer;color:var(--text);display:flex;align-items:center;justify-content:center;transition:all .12s;user-select:none;box-shadow:var(--shadow)}
.pin-key:active{background:var(--bg4);transform:scale(.93)}
.pin-key.fn{background:transparent;box-shadow:none;font-size:20px;color:var(--text2)}
.pin-error{font-size:13px;color:var(--red);min-height:18px;margin-top:6px;font-weight:600}
.pin-attempts{font-size:11px;color:var(--text3);margin-top:4px}

/* ── TOP BAR ── */
.topbar{padding:calc(var(--safe-top) + 14px) 18px 12px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;background:var(--bg)}
.t-title{font-size:22px;font-weight:800;letter-spacing:-.5px}
.t-sub{font-size:11.5px;color:var(--text3);margin-top:2px;font-weight:500}
.t-r{display:flex;gap:6px;align-items:center}
.t-ic{width:38px;height:38px;border-radius:12px;background:var(--bg2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:var(--shadow)}
.t-ic i{font-size:19px;color:var(--text2)}
.t-ic:active{transform:scale(.94)}

.content{flex:1;overflow-y:auto;padding:6px 16px calc(var(--safe-bot) + 96px);-webkit-overflow-scrolling:touch}

/* ── BOTTOM NAV ── */
.nav{position:absolute;bottom:0;left:0;right:0;display:flex;background:color-mix(in srgb,var(--bg2) 85%,transparent);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-top:1px solid var(--border);padding:8px 6px calc(var(--safe-bot) + 8px);justify-content:space-around}
.ni{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:10px;color:var(--text3);cursor:pointer;padding:6px 4px;border:none;background:none;flex:1;font-weight:600;transition:color .15s}
.ni i{font-size:23px;transition:transform .15s}
.ni.on{color:var(--accent)}
.ni.on i{transform:translateY(-1px)}

/* ── HERO ── */
.hero{position:relative;border-radius:var(--rx);padding:20px 20px 18px;color:#fff;overflow:hidden;margin:8px 0 14px;background:linear-gradient(135deg,#1e2a52,#3b2a6b 55%,#5b2a72);box-shadow:0 12px 30px rgba(30,42,82,.35)}
.hero::after{content:"";position:absolute;top:-40px;right:-30px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.08)}
.hero::before{content:"";position:absolute;bottom:-60px;left:-20px;width:150px;height:150px;border-radius:50%;background:rgba(255,255,255,.05)}
.hero-l{font-size:12px;opacity:.78;font-weight:600;letter-spacing:.04em;position:relative}
.hero-v{font-size:34px;font-weight:800;letter-spacing:-1px;margin:5px 0 14px;position:relative}
.hero-row{display:flex;gap:10px;position:relative}
.hero-stat{flex:1;background:rgba(255,255,255,.12);border-radius:13px;padding:9px 11px;backdrop-filter:blur(4px)}
.hero-sl{font-size:10.5px;opacity:.8;margin-bottom:2px}
.hero-sv{font-size:15px;font-weight:700;letter-spacing:-.3px}

/* ── STAT GRID ── */
.sg{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px}
.sc{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:13px 14px;box-shadow:var(--shadow)}
.sl{font-size:11.5px;color:var(--text3);margin-bottom:4px;font-weight:600}
.sv{font-size:20px;font-weight:800;letter-spacing:-.4px}
.g{color:var(--green)}.r{color:var(--red)}.b{color:var(--blue)}.w{color:var(--orange)}.p{color:var(--purple)}

.sec{font-size:12px;font-weight:700;color:var(--text2);letter-spacing:.01em;margin:20px 2px 10px;display:flex;justify-content:space-between;align-items:center}
.sec-a{font-size:12px;color:var(--accent);cursor:pointer;font-weight:600;display:flex;align-items:center;gap:3px}

.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px;box-shadow:var(--shadow)}
.row{display:flex;align-items:center;gap:12px}
.name{font-size:15px;font-weight:650;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.badge{font-size:10px;padding:3px 9px;border-radius:99px;font-weight:700;flex-shrink:0;letter-spacing:.02em}
.bcc{background:var(--red-bg);color:var(--red)}.bsav{background:var(--green-bg);color:var(--green)}.bew{background:var(--orange-bg);color:var(--orange)}.bsub{background:var(--blue-bg);color:var(--blue)}.bloan{background:var(--purple-bg);color:var(--purple)}

/* ── CREDIT CARD VISUAL ── */
.cc{position:relative;border-radius:var(--rl);padding:16px 17px;color:#fff;overflow:hidden;margin-bottom:11px;box-shadow:0 8px 22px rgba(16,24,40,.22)}
.cc::after{content:"";position:absolute;top:-50px;right:-30px;width:140px;height:140px;border-radius:50%;background:rgba(255,255,255,.1)}
.cc-top{display:flex;align-items:flex-start;justify-content:space-between;position:relative;margin-bottom:18px}
.cc-name{font-size:15px;font-weight:700}
.cc-due{font-size:11px;opacity:.82;margin-top:2px}
.cc-owed-l{font-size:11px;opacity:.8;position:relative}
.cc-owed{font-size:25px;font-weight:800;letter-spacing:-.5px;position:relative;margin:1px 0 12px}
.cc-bar{height:6px;border-radius:99px;background:rgba(255,255,255,.25);overflow:hidden;position:relative}
.cc-bar i{display:block;height:100%;border-radius:99px;background:#fff}
.cc-foot{display:flex;justify-content:space-between;font-size:11px;opacity:.85;margin-top:7px;position:relative}
.cc-acts{display:flex;gap:7px;margin:-3px 0 11px}

/* ── ACCOUNT ROW (saving / ew) ── */
.acct{display:flex;align-items:center;gap:12px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:13px 14px;margin-bottom:10px;box-shadow:var(--shadow)}
.acct-m{flex:1;min-width:0}
.acct-n{font-size:14.5px;font-weight:650}
.acct-s{font-size:11.5px;color:var(--text3);margin-top:2px}
.acct-b{text-align:right;flex-shrink:0}
.acct-v{font-size:17px;font-weight:800;letter-spacing:-.3px}
.acct-acts{display:flex;gap:7px;margin-left:8px}
.mini{width:34px;height:34px;border-radius:11px;border:1px solid var(--border2);background:var(--bg2);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);flex-shrink:0}
.mini i{font-size:16px}
.mini:active{transform:scale(.92)}
.mini.g{color:var(--green);background:var(--green-bg);border-color:transparent}
.mini.w{color:var(--orange);background:var(--orange-bg);border-color:transparent}
.mini.del{color:var(--red)}

.dg{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-top:12px}
.db{background:var(--bg3);border-radius:11px;padding:9px 11px}
.dl{font-size:11px;color:var(--text3);margin-bottom:2px;font-weight:500}
.dv{font-size:14px;font-weight:700}
.dv.r{color:var(--red)}.dv.g{color:var(--green)}.dv.w{color:var(--orange)}.dv.b{color:var(--blue)}
.prog{margin-top:12px}
.pl{display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:5px;font-weight:500}
.pt{background:var(--bg4);border-radius:99px;height:6px;overflow:hidden}
.pf{height:100%;border-radius:99px;transition:width .4s}
.acts{display:flex;gap:7px;margin-top:12px;flex-wrap:wrap}
.btn{font-size:12.5px;padding:8px 13px;border-radius:11px;border:1px solid var(--border2);background:var(--bg2);color:var(--text2);cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap;font-weight:650}
.btn:active{transform:scale(.96)}
.btn.pay{background:var(--blue-bg);border-color:transparent;color:var(--blue)}
.btn.topup{background:var(--green-bg);border-color:transparent;color:var(--green)}
.btn.spd{background:var(--orange-bg);border-color:transparent;color:var(--orange)}
.btn.del{color:var(--red);border-color:transparent;background:transparent;padding:8px 10px}

.add-btn{width:100%;padding:14px;border-radius:var(--r);border:1.5px dashed var(--border2);background:transparent;color:var(--text3);cursor:pointer;font-size:13.5px;display:flex;align-items:center;justify-content:center;gap:7px;margin-bottom:10px;font-weight:650}
.add-btn:active{background:var(--bg3)}
.empty{text-align:center;padding:40px 20px;color:var(--text3)}
.empty-ic{width:64px;height:64px;border-radius:20px;background:var(--bg3);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
.empty-ic i{font-size:30px;color:var(--text3)}
.et{font-size:15px;font-weight:700;color:var(--text2);margin-bottom:6px}
.es{font-size:13px;line-height:1.55}

/* ── MODAL ── */
.mb{position:absolute;inset:0;background:rgba(8,12,20,.55);z-index:50;display:flex;align-items:flex-end;backdrop-filter:blur(2px);animation:fade .2s}
@keyframes fade{from{opacity:0}to{opacity:1}}
.md{background:var(--bg2);border-radius:var(--rx) var(--rx) 0 0;padding:14px 20px calc(var(--safe-bot) + 26px);width:100%;max-height:92dvh;overflow-y:auto;animation:slideup .28s cubic-bezier(.2,.9,.3,1)}
@keyframes slideup{from{transform:translateY(100%)}to{transform:translateY(0)}}
.md-handle{width:38px;height:5px;border-radius:3px;background:var(--border2);margin:0 auto 18px}
.md-title{font-size:18px;font-weight:800;margin-bottom:18px;display:flex;align-items:center;gap:11px;letter-spacing:-.3px}
.md-ic{width:36px;height:36px;border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.md-ic i{font-size:19px}
.field{margin-bottom:15px}
.field label{display:block;font-size:12px;color:var(--text2);margin-bottom:7px;font-weight:650}
.field input,.field select,.field textarea{width:100%;border-radius:12px;border:1.5px solid var(--border2);padding:13px 14px;font-size:15px;color:var(--text);background:var(--bg3);outline:none;-webkit-appearance:none;font-family:inherit}
.field input:focus,.field select:focus{border-color:var(--accent);background:var(--bg2)}
.field input.big{font-size:26px;font-weight:800;letter-spacing:-.5px}
.field-row{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.ma{display:flex;gap:10px;margin-top:22px}
.ma button{flex:1;padding:15px;border-radius:14px;font-size:15px;font-weight:700;cursor:pointer;border:1px solid var(--border2);background:var(--bg3);color:var(--text2)}
.ma button:active{transform:scale(.98)}
.ma .ok{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border-color:transparent;box-shadow:0 4px 14px rgba(37,99,235,.3)}
.ma .ok.g{background:linear-gradient(135deg,#0e9f6e,#0b8f74);box-shadow:0 4px 14px rgba(14,159,110,.3)}
.pill-row{display:flex;gap:7px;flex-wrap:wrap;margin-top:6px}
.pill{font-size:13px;padding:9px 15px;border-radius:99px;border:1.5px solid var(--border2);cursor:pointer;color:var(--text2);background:var(--bg2);font-weight:600}
.pill:active{transform:scale(.96)}
.pill.on{background:var(--accent);color:#fff;border-color:transparent}
.pill.og{background:var(--green);color:#fff;border-color:transparent}
.ib{border-radius:13px;padding:12px 14px;margin-bottom:14px;font-size:13px;display:flex;gap:10px;align-items:center;line-height:1.5;font-weight:500}
.ib i{font-size:18px;flex-shrink:0}
.ib.b{background:var(--blue-bg);color:var(--blue)}.ib.g{background:var(--green-bg);color:var(--green)}.ib.w{background:var(--orange-bg);color:var(--orange)}

/* ── ICON PICKER ── */
.icon-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-top:8px;max-height:248px;overflow-y:auto;padding:2px}
.ig-item{display:flex;flex-direction:column;align-items:center;gap:5px;padding:9px 4px;border-radius:14px;cursor:pointer;border:2px solid transparent;transition:all .12s}
.ig-item.sel{border-color:var(--accent);background:var(--blue-bg)}
.ig-item:active{transform:scale(.95)}
.ig-label{font-size:9.5px;color:var(--text3);text-align:center;line-height:1.15;font-weight:600;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cdots{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}
.cdot{width:30px;height:30px;border-radius:50%;cursor:pointer;border:3px solid transparent;box-shadow:inset 0 0 0 2px var(--bg2)}
.cdot.on{box-shadow:inset 0 0 0 2px var(--bg2),0 0 0 2px var(--text)}

.po{border:1.5px solid var(--border);border-radius:13px;padding:11px 13px;cursor:pointer;display:flex;align-items:center;gap:11px;margin-bottom:8px;background:var(--bg2)}
.po.on{border-color:var(--accent);background:var(--blue-bg)}
.po-n{font-size:14px;font-weight:650}
.po-s{font-size:11.5px;color:var(--text3);margin-top:1px}
.po-lbl{font-size:10px;color:var(--text3);font-weight:700;letter-spacing:.04em;text-transform:uppercase;margin:11px 0 6px}

.cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:6px}
.cat-btn{padding:11px 12px;border-radius:12px;border:1.5px solid var(--border);background:var(--bg2);cursor:pointer;font-size:12.5px;color:var(--text2);display:flex;align-items:center;gap:8px;text-align:left;font-weight:600;position:relative}
.cat-btn i{font-size:17px;flex-shrink:0}
.cat-btn.on{background:var(--orange-bg);color:var(--orange);border-color:transparent}
.cat-btn.add-c{border-style:dashed;color:var(--accent);border-color:var(--accent)}
.cat-del{position:absolute;top:3px;right:4px;font-size:13px;color:var(--red);padding:2px}

/* ── TXN LIST ── */
.txn{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
.txn:last-child{border-bottom:none}
.txn-ic{width:38px;height:38px;border-radius:12px;background:var(--bg3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.txn-ic i{font-size:18px;color:var(--text2)}
.txn-m{flex:1;min-width:0}
.txn-n{font-size:14px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.txn-s{font-size:11.5px;color:var(--text3);margin-top:2px}
.txn-a{font-size:15px;font-weight:800;flex-shrink:0;letter-spacing:-.3px}
.txn-a.r{color:var(--red)}.txn-a.g{color:var(--green)}
.txn-x{display:flex;align-items:center;gap:6px}
.txn-x i{font-size:18px;cursor:pointer;padding:3px}
.dh{display:flex;justify-content:space-between;align-items:center;margin:18px 2px 8px}
.dh-l{font-size:13px;font-weight:700;color:var(--text2)}
.dh-r{font-size:13px;font-weight:700;color:var(--red)}

/* ── AA ── */
.aa-p{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);margin-bottom:10px;overflow:hidden;box-shadow:var(--shadow)}
.aa-h{display:flex;align-items:center;gap:12px;padding:14px;cursor:pointer}
.aa-av{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;flex-shrink:0}
.aa-info{flex:1;min-width:0}
.aa-name{font-size:15px;font-weight:700}
.aa-sub{font-size:11.5px;color:var(--text3);margin-top:2px}
.aa-bal{text-align:right;flex-shrink:0}
.aa-num{font-size:17px;font-weight:800;letter-spacing:-.3px}
.aa-lbl{font-size:10px;color:var(--text3);margin-top:1px}
.aa-body{border-top:1px solid var(--border);padding:0 14px}
.aa-txn{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:1px solid var(--border)}
.aa-txn:last-child{border-bottom:none}
.aa-txn-ic{width:34px;height:34px;border-radius:10px;background:var(--bg3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.aa-txn-ic i{font-size:16px;color:var(--text2)}
.aa-txn-m{flex:1;min-width:0}
.aa-txn-n{font-size:13.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.aa-txn-s{font-size:11px;color:var(--text3);margin-top:1px}
