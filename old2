// Image upload → downscale to 120px square → base64 (keeps storage small)
function onIconUpload(input){
  const f=input.files&&input.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=e=>{const img=new Image();img.onload=()=>{const S=120,c=document.createElement('canvas');c.width=S;c.height=S;const ctx=c.getContext('2d');const ratio=Math.max(S/img.width,S/img.height);const w=img.width*ratio,h=img.height*ratio;ctx.drawImage(img,(S-w)/2,(S-h)/2,w,h);U.selCustomImg=c.toDataURL('image/jpeg',0.82);U.selIconId=null;render();};img.onerror=()=>toast('图片读取失败');img.src=e.target.result;};
  r.readAsDataURL(f);
}

