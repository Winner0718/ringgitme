function iconPicker(filter){
  let icons=ICONS;
  if(filter==='bank')icons=ICONS.filter(i=>i.cat==='bank'||i.cat==='gen');
  else if(filter==='ew')icons=ICONS.filter(i=>i.cat==='ew'||i.cat==='gen');
  else if(filter==='app')icons=ICONS.filter(i=>i.cat==='app'||i.cat==='gen');
  let h=`<div class="icon-grid">`;
  h+=`<label class="ig-item ${U.selCustomImg?'sel':''}" style="cursor:pointer">
    <input type="file" accept="image/*" style="display:none" onchange="onIconUpload(this)"/>
    ${U.selCustomImg?`<img src="${U.selCustomImg}" style="width:42px;height:42px;border-radius:12px;object-fit:cover"/>`:`<div style="width:42px;height:42px;border-radius:12px;background:var(--bg4);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:20px"><i class="ti ti-camera-plus"></i></div>`}
