function shade(hex,f){try{let c=hex.replace('#','');if(c.length===3)c=c.split('').map(x=>x+x).join('');const n=parseInt(c,16);let r=Math.min(255,Math.max(0,Math.round(((n>>16)&255)*f)));let g=Math.min(255,Math.max(0,Math.round(((n>>8)&255)*f)));let b=Math.min(255,Math.max(0,Math.round((n&255)*f)));return'#'+[r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('');}catch{return hex;}}

// Renders a brand icon tile (or uploaded custom image)
function iconHTML(spec,size=38,radius=12){
  size=Number(size);
  if(typeof spec==='string')spec=gi(spec);
  if(!spec)spec=gi('star');
  if(spec.img){return `<img src="${spec.img}" style="width:${size}px;height:${size}px;border-radius:${radius}px;object-fit:cover;flex-shrink:0;box-shadow:0 1px 3px rgba(0,0,0,.15)" alt=""/>`;}
  const grad=spec.grad?`linear-gradient(140deg,${spec.bg},${spec.grad})`:spec.bg;
  let inner,fs;
  if(spec.glyph){fs=Math.round(size*0.5);inner=`<i class="ti ${spec.glyph}"></i>`;}
  else{const len=(spec.mono||'?').length;fs=len>=3?Math.round(size*0.30):len===2?Math.round(size*0.40):Math.round(size*0.52);inner=`<span style="font-weight:800;letter-spacing:-.5px;line-height:1">${spec.mono}</span>`;}
  return `<div style="width:${size}px;height:${size}px;border-radius:${radius}px;background:${grad};color:${spec.fg||'#fff'};display:flex;align-items:center;justify-content:center;font-size:${fs}px;flex-shrink:0;box-shadow:0 1px 3px rgba(0,0,0,.15)">${inner}</div>`;
}
// icon for a stored object (card/sub) honoring its uploaded img
